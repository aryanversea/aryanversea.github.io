<!DOCTYPE html>
<html lang="en">
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GrowthWithAryan</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #0f172a;
  color: white;
}

header {
  text-align: center;
  padding: 60px 20px;
}

h1 {
  font-size: 34px;
}

p {
  color: #cbd5f5;
}

.btn {
  background: #22c55e;
  padding: 14px 25px;
  color: white;
  text-decoration: none;
  border-radius: 6px;
  display: inline-block;
  margin-top: 15px;
  font-weight: bold;
}

.section {
  padding: 40px 20px;
  text-align: center;
}

.cards {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.card {
  background: #1e293b;
  padding: 20px;
  border-radius: 12px;
  box-shadow: 0px 5px 15px rgba(0,0,0,0.3);
}

.pricing {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.price-card {
  background: #1e293b;
  padding: 25px;
  border-radius: 12px;
}

footer {
  text-align: center;
  padding: 20px;
  background: #020617;
}

/* Desktop view */
@media(min-width:768px){
  .cards, .pricing {
    flex-direction: row;
    justify-content: center;
  }
  .card, .price-card {
    width: 250px;
  }
}
</style>
</head>

<body>

<header>
<h1>Grow Your Business with Instagram 🚀</h1>
<p>I help local businesses get real customers using reels & smart marketing</p>
<a class="btn" href="https://wa.me/918076401533">📲 Contact on WhatsApp</a>
</header>

<div class="section">
<h2>Our Services</h2>

<div class="cards">
<div class="card">📈 Instagram Growth</div>
<div class="card">🎥 Reels & Content</div>
<div class="card">📍 Local Promotion</div>
</div>

</div>

<div class="section">
<h2>Pricing Plans</h2>

<div class="pricing">
<div class="price-card">
<h3>Basic</h3>
<p>₹5000/month</p>
<p>10 posts/reels</p>
</div>

<div class="price-card">
<h3>Standard</h3>
<p>₹8000/month</p>
<p>20 posts + reels</p>
</div>

<div class="price-card">
<h3>Premium</h3>
<p>₹12000/month</p>
<p>Full management</p>
</div>
</div>

</div>

<div class="section">
<h2>About Me</h2>
<p>I’m Aryan. I help local businesses grow online and bring real customers using modern marketing strategies.</p>
</div>

<footer>
<p>📞 8076401533</p>
<p>📍 India</p>
</footer>

</body>
</html>
